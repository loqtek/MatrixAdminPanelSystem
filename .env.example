# Database Configuration (used by local `uvicorn` / non-Docker runs)
DATABASE_URL=sqlite:///./maps.db
# For PostgreSQL locally: DATABASE_URL=postgresql://user:password@localhost:5432/maps_db

# Docker Compose backend only — overrides host DATABASE_URL inside the container.
# Leave unset for SQLite (uses ./backend/sqlite_data via compose). For Postgres in Docker:
# DOCKER_DATABASE_URL=postgresql://maps_user:maps_password@db:5432/maps_db

# JWT — generate with: openssl rand -hex 32
# Backend signs cookies; Next.js middleware verifies the same secret.
SECRET_KEY=
# Must match SECRET_KEY (used by middleware.ts for JWT verification)
JWT_SECRET=

# Local development only: allows placeholder SECRET_KEY values (never use in production)
# ALLOW_INSECURE_DEFAULT_SECRET=true

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Set true when serving the app over HTTPS (recommended in production)
# COOKIE_SECURE=true

# Optional: dedicated Fernet key for Matrix token encryption at rest (defaults to key derived from SECRET_KEY)
# MATRIX_TOKEN_ENCRYPTION_KEY=

# Restrict config/log file paths to these directory roots (comma-separated). Use * to disable (not recommended).
# ALLOWED_FILE_ROOTS=/etc/matrix-synapse,/var/log/matrix-synapse

# Browser → Next.js same-origin /api/* proxy (fixes SameSite=Lax cookies; avoid cross-origin API URL).
# Leave NEXT_PUBLIC_API_URL empty (or set to same-origin). Point BACKEND_INTERNAL_URL at the FastAPI server.
NEXT_PUBLIC_API_URL=
BACKEND_INTERNAL_URL=http://127.0.0.1:8000

# CORS Origins (comma-separated, used by backend) — include every origin used to open the UI (e.g. http://10.0.0.1:3000)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://YOUR_LAN_IP:3000

# Matrix Server Configuration
MATRIX_SERVER_URL=https://matrix.example.com

# Verbose API errors (do not enable in production)
# DEBUG=false
